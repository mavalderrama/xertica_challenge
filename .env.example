# Django
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=insecure-dev-key-change-in-production

# PostgreSQL
POSTGRES_DB=compliance_db
POSTGRES_USER=compliance
POSTGRES_PASSWORD=compliance
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# GCP
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Vertex AI / Gemini
GEMINI_MODEL=gemini-2.0-flash-001

# GCS
GCS_BUCKET_NAME=your-compliance-bucket

# Langfuse
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000

# Feature flags (set to "false" to use real GCP services)
USE_MOCK_BQ=true
USE_MOCK_GCS=true

# Allowed hosts (comma-separated, for production)
ALLOWED_HOSTS=localhost,127.0.0.1
